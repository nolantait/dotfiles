{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["opencode"],
  "agent": {
    "coder": {
      "prompt": "{file:./prompts/system.md}"
    },
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "formatter": false,
  "lsp": true,
  "share": "disabled",
  "permission": {
    "webfetch": "ask",
    "websearch": "ask",

    "edit": "allow",
    "question": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "skill": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",

    "bash": {
      "*": "ask",
      "bin/rails *": "allow",
      "bin/rspec *": "allow",
      "bin/rubocop *": "allow",
      "bundle *": "allow",
      "cargo *": "allow",
      "echo *": "allow",
      "find *": "allow",
      "gem *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "rails *": "allow",
      "rg *": "allow",
      "rspec *": "allow",
      "tail *": "allow",
      "which *": "allow",
      "xargs *": "allow",
    },

    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
}
